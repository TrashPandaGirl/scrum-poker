# Kopiere diese Datei nach `.env` und trage die Firebase-Web-Config deines Projekts ein.
# (Firebase Console → Projekteinstellungen → Deine Apps → SDK-Konfiguration.)
# Diese Werte sind öffentlich (landen im Frontend-Bundle) – der Schutz kommt aus den
# Firestore-Rules + API-Key-Beschränkung, nicht aus Geheimhaltung.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_FB_MEASUREMENT_ID=
